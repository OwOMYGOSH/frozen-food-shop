# ============================================================
#  .env.example — 複製這個檔案，改名為 .env，填入真實的值
#  ⚠️  .env 絕對不能 commit 到 Git！
# ============================================================

# ----- PostgreSQL -----
DB_NAME=frozendb
DB_USER=appuser
DB_PASSWORD=changeme_strong_password

# ----- Redis -----
REDIS_PASSWORD=changeme_redis_password

# ----- MinIO (物件儲存 / 圖片) -----
MINIO_USER=minioadmin
MINIO_PASSWORD=changeme_minio_password

# ----- JWT -----
JWT_SECRET=changeme_at_least_256bit_secret_key_here_please_use_random
JWT_EXPIRY_SECONDS=3600
JWT_REFRESH_EXPIRY_SECONDS=604800

# ----- ECPay 綠界金流 -----
# 測試用金鑰：https://developers.ecpay.com.tw/ 申請後填入
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
ECPAY_IS_SANDBOX=true

# ----- App -----
APP_DOMAIN=http://localhost
CORS_ORIGINS=http://localhost:4200
